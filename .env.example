# OpenAI API Key (required for OpenAI agent and LLM-as-a-judge evals)
OPENAI_API_KEY=your_openai_api_key_here

# Phoenix Configurations
PHOENIX_PROJECT_NAME=phoenix-demo-agent

# Set to local Phoenix endpoint (default)
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces

# If using Phoenix Cloud, uncomment and configure these:
# PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/v1/traces
# PHOENIX_API_KEY=your_phoenix_cloud_api_key_here
