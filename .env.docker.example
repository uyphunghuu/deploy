# ══════════════════════════════════════════════════════════════════
# SLABAI – Local Docker Environment
# Copy file này thành .env.docker và điền vào các giá trị cần thiết.
# File .env.docker KHÔNG được commit lên git (đã có trong .gitignore).
# ══════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────
APP_NAME=SLABAI Backend
ENVIRONMENT=development
DEBUG=true

# ── Database (tự động override bởi docker-compose) ────────────────
# DATABASE_URL được set sẵn trong docker-compose.yml khi chạy local
# DATABASE_URL=postgresql+asyncpg://slabai:slabai_local_secret@postgres:5432/slabai

# ── Supabase Auth (dùng Supabase cloud project của bạn) ──────────
# Nếu chưa có, bỏ trống – backend sẽ chạy nhưng auth sẽ không hoạt động
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_SECRET=

# ── LLM (bắt buộc để AI Coach hoạt động) ────────────────────────
# Chọn 1 trong 2: openai hoặc gemini
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Nếu dùng OpenAI:
OPENAI_API_KEY=sk-...your-openai-key...

# Nếu dùng Gemini (thay LLM_PROVIDER=gemini và LLM_MODEL=gemini-1.5-flash):
# GEMINI_API_KEY=your-gemini-key

# ── Langfuse Tracing (tuỳ chọn) ──────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Strava Integration (tuỳ chọn) ────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# ── Frontend public variables ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Đặt thành "true" để frontend dùng mock data thay vì gọi backend thật
NEXT_PUBLIC_USE_MOCK_CHAT=false
